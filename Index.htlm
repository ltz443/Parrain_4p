<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Parrain 4P</title>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
    <style>
        body { margin: 0; background: #0A0B0F; color: white; font-family: sans-serif; text-align: center; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 15px; }
        .card { background: #111318; border: 1px solid #1A1E2A; padding: 15px; border-radius: 12px; }
        .bonus { color: #4FFFA0; font-weight: bold; font-size: 1.2em; }
        h1 { color: #4FFFA0; padding: 20px; border-bottom: 1px solid #1A1E2A; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // Connexion à ton Supabase
        const supabaseUrl = 'https://wjduwqjcfbbhtkzzdkga.supabase.co';
        const supabaseKey = 'sb_publishable_IBBHjx4pchtNmbTAXNTQ7Q_oOi7Piso';
        const client = supabase.createClient(supabaseUrl, supabaseKey);

        function App() {
            const [offres, setOffres] = useState([]);

            useEffect(() => {
                client.from('offres').select('*').then(({ data }) => {
                    if (data) setOffres(data);
                });
            }, []);

            return (
                <div>
                    <h1>PARRAIN 4P</h1>
                    <div className="grid">
                        {offres.length === 0 ? <p>Chargement...</p> : offres.map(o => (
                            <div key={o.id} className="card">
                                <div style={{fontSize: '10px', opacity: 0.6}}>{o.categorie}</div>
                                <div>{o.nom}</div>
                                <div className="bonus">{o.bonus}</div>
                            </div>
                        ))}
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
